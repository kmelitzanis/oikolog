APP_NAME=Oikolog
APP_ENV=production
## Generate a base64 APP_KEY for Laravel (run `php artisan key:generate` locally).
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=Europe/Athens

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=oikolog
DB_USERNAME=oikolog
DB_PASSWORD=secret

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=525600

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080

FILESYSTEM_DRIVER=public

ADMIN_EMAIL=admin@oikolog.local
ADMIN_PASSWORD=changeme123
